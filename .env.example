# =============================================================================
# ENVIRONMENT CONFIGURATION - Copy to .env and fill in actual values
# =============================================================================

# --- Admin Authentication ---
# Set these for initial admin account; after first login, use /admin/change-credentials
# For production, ensure ADMIN_SECRET_KEY is a strong random value
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
ADMIN_SECRET_KEY=your-secret-key-for-session-encryption

# --- Google APIs ---
# Get from Google Cloud Console: https://console.cloud.google.com/
GEMINI_API_KEY=your-google-gemini-api-key-here
GOOGLE_APPLICATION_CREDENTIALS=path/to/google-service-account.json

# --- Google Cloud Service Account (for Merchant API - Phase 3)
# Download JSON from GCP IAM > Service Accounts
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com

# --- CJ Dropshipping API ---
# Get credentials from: https://developers.cjdropshipping.com/
CJ_EMAIL=your-cj-dropshipping-email@example.com
CJ_API_KEY=your-cj-api-key-here
CJ_ACCESS_TOKEN=auto-generated-by-token-refresher
CJ_API_ENDPOINT=https://developers.cjdropshipping.com/api2.0/v1

# --- Payment Processing (Paystack) ---
# Get keys from: https://dashboard.paystack.com/
PAYSTACK_PUBLIC_KEY=pk_live_or_test_key_here
PAYSTACK_SECRET_KEY=sk_live_or_test_key_here

# --- Email/SMTP (Brevo) ---
# Get credentials from: https://app.brevo.com/
BREVO_API_KEY=your-brevo-api-key-here
SMTP_SERVER=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-brevo-smtp-password

# --- Notifications (Telegram) ---
# Get from Telegram Bot Father
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# --- Currency/Exchange Rate ---
# Free tier available at: https://exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your-exchange-rate-api-key

# --- Merchant Center Feed Configuration ---
# GMC Merchant ID and feed schedule
GMC_MERCHANT_ID=your-google-merchant-center-id
FEED_SCHEDULE_HOUR=2
FEED_SCHEDULE_MINUTE=0

# --- Database (if migrating from JSON)
# PostgreSQL example for production
DATABASE_URL=postgresql://username:password@localhost:5432/ecommerce_db

# --- Deployment/Runtime ---
ENVIRONMENT=production
DEBUG=False
PORT=5000
LOG_LEVEL=INFO

# --- UCP Phase 3 Specific ---
# Merchant API Settings
MERCHANT_API_ENABLED=False
MERCHANT_API_FEED_SYNC_INTERVAL_MINUTES=60
MERCHANT_API_INSIGHTS_POLLING_ENABLED=False

# --- UCP Phase 4 Specific ---
# MCP/A2A Settings (coming in Phase 4)
MCP_SERVER_ENABLED=False
MCP_LISTEN_PORT=3000
A2A_SESSION_TIMEOUT_MINUTES=30
